<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_background">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <ImageButton
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_launcher_foreground"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="10dp"
            android:text="@string/library_tittle"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <ImageButton
            android:id="@+id/btnImportModel"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="@string/import_model"/>

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="@string/settings_title"/>


    </LinearLayout>

    <!-- Filter chips -->
    <!-- Filter chips -->

    <!-- Item count label -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="4dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                style="@style/Widget.App.LibraryChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:checked="false"
                android:text="@string/filter_all"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAlphabetical"
                style="@style/Widget.App.LibraryChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:text="@string/filter_alphabetical"
                android:textSize="12sp"
                app:checkedIconVisible="false"
                app:chipIcon="@drawable/ic_sort_asc"
                app:chipIconSize="16dp"
                app:chipIconVisible="true"
                app:iconStartPadding="4dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipRecent"
                style="@style/Widget.App.LibraryChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:checked="true"
                android:text="@string/filter_recent"
                android:textSize="12sp"
                app:checkedIconVisible="false"
                app:chipIcon="@drawable/ic_sort_desc"
                app:chipIconSize="16dp"
                app:chipIconVisible="true"
                app:iconStartPadding="4dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSize"
                style="@style/Widget.App.LibraryChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:text="@string/filter_size"
                android:textSize="12sp"
                app:checkedIconVisible="false"
                app:chipIcon="@drawable/ic_sort_asc"
                app:chipIconSize="16dp"
                app:chipIconVisible="true"
                app:iconStartPadding="4dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipImported"
                style="@style/Widget.App.LibraryChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:text="@string/filter_imported"
                android:textSize="12sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSaved"
                style="@style/Widget.App.LibraryChip"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/filter_profile"
                android:textSize="12sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvItemCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.06"
        android:textColor="@color/text_secondary" />

    <!-- Grid of model cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvModelLibrary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

</LinearLayout>