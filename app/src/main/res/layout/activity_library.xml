<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_background">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="8dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/library_tittle"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- Import .glb from device storage -->
        <ImageButton
            android:id="@+id/btnImportModel"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_add"
            android:background="@android:color/transparent"
            android:contentDescription="@string/import_model"
            android:scaleType="centerInside"
            android:padding="8dp"
            app:tint="@color/icon_tint" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_settings"
            android:background="@android:color/transparent"
            android:contentDescription="@string/settings_title"
            android:scaleType="centerInside"
            android:padding="8dp"
            app:tint="@color/icon_tint" />

    </LinearLayout>

    <!-- Grid of model cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvModelLibrary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"/>

</LinearLayout>