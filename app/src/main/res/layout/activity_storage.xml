<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="5dp"
            android:text="@string/manage_storage"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- "Delete all" icon button in top-right -->
        <ImageButton
            android:id="@+id/btnDeleteAll"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="@string/clear_cache"
            app:tint="@color/danger_surface" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── Storage summary card ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:background="@color/layout_background">

                <!-- Left: label + size + model count -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_storage_used"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/tvTotalSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 MB"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_section_label"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tvModelCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 downloaded models"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>

                <!-- Right: progress ring + RulerSeekBar quota slider -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ProgressBar
                        android:id="@+id/progressStorage"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/circular_progress"
                        android:rotation="-90" />

                    <!--
                        RulerSeekBar is horizontal by nature.
                        Rotating 270° makes it vertical. Because Android reserves
                        layout space from declared dimensions (before rotation),
                        width = desired visual HEIGHT and height = desired visual WIDTH.
                        160dp height → the ruler's own onMeasure minimum (it needs ~160px
                        for label + ticks + thumb to fit without clipping).
                    -->
                    <com.example.pracazaliczeniowa.Helpers.RulerSeekBar
                        android:id="@+id/sliderQuota"
                        android:layout_width="60dp"
                        android:layout_height="80dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Clear Storage button ──────────────────────────────── -->
            <Button
                android:id="@+id/btnClearStorage"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/clear_storage"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/danger_surface"
                android:layout_marginBottom="24dp"/>

            <!-- ── Cached models list label ──────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cached_models"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <!-- Dynamic model list injected here by StorageActivity -->
            <LinearLayout
                android:id="@+id/containerModels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>