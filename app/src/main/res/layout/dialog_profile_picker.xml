<?xml version="1.0" encoding="utf-8"?>
<!--
    res/layout/dialog_profile_picker.xml
    Root layout for ProfilePickerDialog.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvProfileDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Profiles"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="12dp"/>

    <!-- Dynamic list of profile slot rows (built in code) -->
    <LinearLayout
        android:id="@+id/profileListContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <!-- "Add named profile" button -->
    <Button
        android:id="@+id/btnAddNamedProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="+ Add named profile…"
        android:textColor="@android:color/white"
        android:backgroundTint="#3D3D3D"/>

</LinearLayout>
