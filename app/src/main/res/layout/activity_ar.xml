<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_ar.xml
    ───────────────
    Added dimensionHud (include of view_model_dimension_label) in the
    bottom-start corner, above the model-controls strip.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <io.github.sceneview.ar.ARSceneView
        android:id="@+id/arSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.example.pracazaliczeniowa.Overlays.MeasureTapeOverlayView
        android:id="@+id/measureOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <!-- ── Settings button – top-start ─────────────────────────────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/btnLibrary"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_arrow_back_white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="Back"/>

        <ImageButton
            android:id="@+id/btnLibrary"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_gravity="top|start"
            android:src="@drawable/ic_library"
            android:background="@drawable/rounded_button"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Model Library"/>
    </LinearLayout>

    <!-- ── Unit toggle – top-end ────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="10dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:background="@drawable/rounded_button"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Settings"/>

        <Button
            android:id="@+id/btnUnit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="cm"
            android:visibility="gone"
            android:background="#88000000"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- ── Measure tape / wireframe / animation toggles – top-end ───────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="120dp"
        android:layout_marginEnd="10dp"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/btnMeasureTapeModeToggle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_measure_tape"
            android:background="@drawable/rounded_button"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:layout_marginBottom="10dp"/>

        <ImageButton
            android:id="@+id/btnWireframeToggle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_wireframe"
            android:background="@drawable/rounded_button"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone"/>

        <!--
            Animation toggle — only shown when a model with animations is
            selected. Hidden by default; ARActivity shows/hides it
            inside selectModel() / deselectModel().
        -->
        <ImageButton
            android:id="@+id/btnAnimationToggle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_animation"
            android:background="@drawable/rounded_button"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="Toggle animation"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- ── Status text + model controls + dimension HUD – bottom ────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:text="Point at a surface to place model"
            android:textColor="@color/AR_text_color"
            android:background="@color/AR_text_background"
            android:padding="8dp"
            android:textSize="14sp" />

        <!-- Dimension HUD anchored to start, sits above the controls bar -->
        <include
            android:id="@+id/dimensionHud"
            layout="@layout/view_model_dimension_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <com.example.pracazaliczeniowa.Overlays.ModelControlOverlayView
            android:id="@+id/modelControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="10dp"
            android:background="@color/AR_layout_background"/>

    </LinearLayout>

</FrameLayout>