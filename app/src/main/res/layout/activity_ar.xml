<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_ar.xml
    ───────────────
    Added dimensionHud (include of view_model_dimension_label) in the
    bottom-start corner, above the model-controls strip.
    Added measure-mode action buttons (delete / revert) at bottom-end,
    shown only while measure mode is active.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <io.github.sceneview.ar.ARSceneView
        android:id="@+id/arSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Settings button – top-start ─────────────────────────────────── -->
    <com.example.pracazaliczeniowa.Overlays.MeasureTapeOverlayView
        android:id="@+id/measureOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="true" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:orientation="vertical"
        android:fitsSystemWindows="true">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_arrow_back_white"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            android:contentDescription="@string/back"/>

        <!--
            Model colour button — shown only when a texture-less model is selected
            (STL / PLY / 3DS that received the grey default PBR material from the
            native converter). Hidden by default; ARActivity toggles visibility
            inside selectModel() / deselectModel().
            The outer FrameLayout layers a solid bg_rect behind a smaller
            patch_rect swatch so the user sees the currently applied colour.
        -->
        <FrameLayout
            android:id="@+id/btnModelColour"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/rounded_button"
            android:visibility="gone"
            android:contentDescription="Change model colour"
            android:clickable="true"
            android:focusable="true">

            <!-- Full-button background tint (tracks current override colour) -->
            <View
                android:id="@+id/modelColourBgRect"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/rounded_button"
                android:alpha="0.35"/>

            <!-- Small swatch square centred inside -->
            <View
                android:id="@+id/modelColourPatchRect"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:background="@drawable/rounded_button"/>

        </FrameLayout>

        <ImageButton
            android:id="@+id/btnLibrary"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_gravity="top|start"
            android:src="@drawable/ic_library"
            android:background="@drawable/rounded_button"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="@string/library_tittle"/>
    </LinearLayout>

    <!-- ── Unit toggle – top-end ────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="10dp"
        android:orientation="horizontal"
        android:fitsSystemWindows="true">

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:background="@drawable/rounded_button"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="@string/settings_title"/>

    </LinearLayout>

    <!-- ── Measure tape / wireframe / animation toggles – top-end ───────── -->
    <!--
        Wrapped in a ScrollView so buttons don't overflow off-screen in
        landscape mode when multiple animation buttons are visible at once.
        layout_height="0dp" + weight trick doesn't work in FrameLayout, so we
        use match_parent and let fitsSystemWindows + the margins bound the size.
    -->
    <ScrollView
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="top|end"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="80dp"
        android:fitsSystemWindows="true"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="false"
        android:clipToPadding="false"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnMeasureTapeModeToggle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_measure_tape"
                android:background="@drawable/rounded_button"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginBottom="10dp"
                android:contentDescription="@string/measure_tap_first"/>

            <!--
                Wall-magnet mode toggle — ic_stack (flat = horizontal planes),
                rotated -90° (counter-clockwise) when in vertical/wall mode.
            -->
            <ImageButton
                android:id="@+id/btnWallMagnet"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_stack"
                android:background="@drawable/rounded_button"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginBottom="10dp"/>

            <ImageButton
                android:id="@+id/btnWireframeToggle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_wireframe"
                android:background="@drawable/rounded_button"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"/>

            <!--
                Rotation ring toggle — shown when a model is selected.
                Full alpha = ring visible; dimmed = ring hidden.
            -->
            <ImageButton
                android:id="@+id/btnRotationRingToggle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_circle_delete"
                android:background="@drawable/rounded_button"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"/>

            <!--
                Animation toggle — only shown when a model with animations is
                selected. Hidden by default; ARActivity shows/hides it
                inside selectModel() / deselectModel().
            -->
            <ImageButton
                android:id="@+id/btnAnimationToggle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_animation"
                android:background="@drawable/rounded_button"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"/>

            <!--
                Stop button — stops animation and resets to frame 0.
                Only shown while animation is playing.
            -->
            <ImageButton
                android:id="@+id/btnAnimationPause"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_play_pause"
                android:background="@drawable/rounded_button"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"/>

            <!--
                Next-animation button — cycles to the next animation track.
                Only shown when the selected model has more than one animation
                and animation is playing.
            -->
            <ImageButton
                android:id="@+id/btnAnimationNext"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_skip_next"
                android:background="@drawable/rounded_button"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:layout_marginBottom="10dp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

    <!-- ── Measure-mode action buttons ─────────────────────────────────── -->
    <!--
        Shown only while measure mode is active (visibility toggled in code).
        Delete  → bottom-start – clears all measure points.
        Revert  → bottom-end   – undoes the last placed point (or last line).
    -->

    <!-- Delete – bottom-start -->
    <ImageButton
        android:id="@+id/btnMeasureDelete"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="24dp"
        android:layout_marginStart="12dp"
        android:src="@drawable/ic_delete"
        android:background="@drawable/rounded_button"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:visibility="gone"
        android:contentDescription="Clear all measure points"
        android:fitsSystemWindows="true"/>

    <!-- Revert – bottom-end -->
    <ImageButton
        android:id="@+id/btnMeasureRevert"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="24dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_revert"
        android:background="@drawable/rounded_button"
        android:scaleType="centerInside"
        android:padding="12dp"
        android:visibility="gone"
        android:contentDescription="Undo last measure point"
        android:fitsSystemWindows="true"/>

    <!-- ── Status text + model controls + dimension HUD – bottom ────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:fitsSystemWindows="true">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:text="@string/status_point_at_surface"
            android:textColor="@color/text_primary"
            android:background="@color/AR_text_background"
            android:padding="8dp"
            android:textSize="14sp" />

        <!-- Dimension HUD anchored to start, sits above the controls bar -->
        <include
            android:id="@+id/dimensionHud"
            layout="@layout/view_model_dimension_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <com.example.pracazaliczeniowa.Overlays.ModelControlOverlayView
            android:id="@+id/modelControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="10dp"
            android:background="@color/AR_layout_background"/>

    </LinearLayout>

</FrameLayout>