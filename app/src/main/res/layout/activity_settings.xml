<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="APPEARANCE"
        android:textSize="12sp"
        android:textColor="@color/accent"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="24dp"
        android:background="@color/card_background"> <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dark mode"
            android:textSize="16sp"
            android:textColor="@color/text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Switch between dark and light theme"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"/> </LinearLayout>

        <Switch
            android:id="@+id/switchDarkMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AR CONTROLS – POSITION"
        android:textSize="12sp"
        android:textColor="@color/accent"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="24dp"
        android:background="@color/card_background"> <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Default position range"
        android:textSize="16sp"
        android:textColor="@color/text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Half-range when AR overlay first opens (1–1000 cm)."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="14dp"/> <TextView
            android:id="@+id/tvPosMidValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="±100 cm"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnPosMidMinus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="−"
                android:textSize="20sp"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_background"
                android:padding="0dp"/> <EditText
            android:id="@+id/etPosMid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="10dp"
            android:inputType="number"
            android:textSize="16sp"
            android:gravity="center"
            android:hint="100"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/edit_text_hint"
            android:background="@android:color/transparent"
            android:singleLine="true"/> <Button
            android:id="@+id/btnPosMidPlus"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="@color/button_text"
            android:backgroundTint="@color/button_background"
            android:padding="0dp"/> </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AR CONTROLS – SCALE"
        android:textSize="12sp"
        android:textColor="@color/accent"
        android:letterSpacing="0.08"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="24dp"
        android:background="@color/card_background"> <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Default scale maximum"
        android:textSize="16sp"
        android:textColor="@color/text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seekbar max when AR overlay first opens. Value = progress ÷ 100. Range: 100–10000."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="14dp"/> <TextView
            android:id="@+id/tvSclMaxValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5.00×"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnSclMaxMinus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="−"
                android:textSize="20sp"
                android:textColor="@color/button_text"
                android:backgroundTint="@color/button_background"
                android:padding="0dp"/> <EditText
            android:id="@+id/etSclMax"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="10dp"
            android:inputType="number"
            android:textSize="16sp"
            android:gravity="center"
            android:hint="500"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/edit_text_hint"
            android:background="@android:color/transparent"
            android:singleLine="true"/> <Button
            android:id="@+id/btnSclMaxPlus"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="@color/button_text"
            android:backgroundTint="@color/button_background"
            android:padding="0dp"/> </LinearLayout>
    </LinearLayout>

</LinearLayout>
</ScrollView>