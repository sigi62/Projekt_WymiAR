<?xml version="1.0" encoding="utf-8"?>
<!--
    view_model_dimension_label.xml
    ──────────────────────────────
    HUD panel shown in the bottom-start corner of the AR screen,
    directly above ModelControlOverlayView.
    It displays Width / Height / Depth of the selected model.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dimensionPanel"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:padding="8dp">

    <!-- Width row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#FFFF4444"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/dimensionW"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFF4444"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="W: – cm" />
    </LinearLayout>

    <!-- Height row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="3dp">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#FF44FF44"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/dimensionH"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF44FF44"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="H: – cm" />
    </LinearLayout>

    <!-- Depth row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="3dp">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#FF4488FF"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/dimensionD"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF4488FF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="D: – cm" />
    </LinearLayout>

</LinearLayout>