<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <TextView
        android:id="@+id/tvSlotName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <Button
        android:id="@+id/btnSlotOverwrite"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="@string/overwrite"
        android:textSize="11sp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginStart="4dp"
        android:backgroundTint="@color/card_image_background"
        android:textColor="@color/text_secondary" />

    <Button
        android:id="@+id/btnSlotLoad"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="@string/load"
        android:textSize="11sp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginStart="4dp"
        android:backgroundTint="@color/card_image_background"
        android:textColor="@color/text_primary" />

    <ImageButton
        android:id="@+id/btnSlotDelete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_delete"
        android:backgroundTint="@android:color/transparent"
        android:contentDescription="@string/delete_profile"
        android:visibility="gone"
        app:tint="@color/danger_surface" />

</LinearLayout>