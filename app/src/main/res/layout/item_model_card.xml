<?xml version="1.0" encoding="utf-8"?>
<!--
    Single card in the model library grid.
    Place this file at: res/layout/item_model_card.xml
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Thumbnail image -->
        <ImageView
            android:id="@+id/imgModelThumbnail"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:contentDescription="Model thumbnail"
            android:background="@color/card_image_background"/>

        <!-- Row: model name + three-dots menu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp"
            android:paddingBottom="2dp">

            <!-- Model name (takes remaining space) -->
            <TextView
                android:id="@+id/tvModelName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center_horizontal"/>

            <!-- Three-dots overflow menu -->
            <ImageButton
                android:id="@+id/btnModelOptions"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_vert"
                android:contentDescription="More options"
                android:scaleType="fitCenter"/>

        </LinearLayout>

        <!-- Badge row: "✓ Saved" and "Imported" sit side by side, centred -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <!-- "✓ Saved" profile badge – shown by adapter when a profile exists -->
            <TextView
                android:id="@+id/tvSavedBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Saved"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:visibility="gone"/>

            <!-- Spacer between badges (only visible when both are shown) -->
            <Space
                android:layout_width="6dp"
                android:layout_height="1dp"/>

            <!-- "Imported" badge – shown for user-imported models only -->
            <TextView
                android:id="@+id/tvImportedBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓ Imported"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>