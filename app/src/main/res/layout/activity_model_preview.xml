<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DCDCDC">

    <io.github.sceneview.SceneView
        android:id="@+id/previewSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <!-- Back button (top-left) -->
    <ImageButton
        android:id="@+id/btnPreviewBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/back"
        android:src="@drawable/ic_arrow_back_white" />

    <!-- Background picker button (top-right) — always visible, hides during crop -->


    <ImageButton
        android:id="@+id/btnBackground"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/rounded_button"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:contentDescription="@string/change_background"
        android:src="@drawable/ic_color_palette" />

    <!--
        Animation toggle — floats top-end below the background button.
        Shown only when the loaded model has animation tracks.
        Hidden by default; ModelPreviewActivity reveals it after loadModel().
    -->
    <ImageButton
        android:id="@+id/btnAnimationToggle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_animation"
        app:tint="@android:color/white"
        android:visibility="gone" />

    <!-- ── Crop overlay (hidden until user taps Set Thumbnail) ────────────
         Sits above the SceneView. The darkened surround is drawn by
         CropOverlayView; this container just holds the confirm/cancel row. -->
    <com.example.pracazaliczeniowa.Overlays.CropOverlayView
        android:id="@+id/cropOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Confirm / Cancel row — shown together with the crop overlay -->
    <LinearLayout
        android:id="@+id/cropConfirmBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCropCancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/cancel" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCropConfirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/save_thumbnail" />

    </LinearLayout>


    <!-- Bottom button row (hidden while crop overlay is active) -->

    <com.example.pracazaliczeniowa.Overlays.RulerSeekBar
        android:id="@+id/rotationSlider"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="80dp"
        android:max="3600"
        android:padding="16dp"
        android:progress="1800" />

    <LinearLayout
        android:id="@+id/normalButtonBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnOpenInAR"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/open_in_ar" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnTakeScreenshot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/set_thumbnail" />

    </LinearLayout>

</FrameLayout>